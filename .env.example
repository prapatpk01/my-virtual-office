# Virtual Office Configuration
# Copy this file to .env and adjust values for your setup.

# Path to your OpenClaw installation
VO_OPENCLAW_PATH=~/.openclaw

# OpenClaw gateway connection
# Default uses host.docker.internal which works on Linux, Windows, and macOS.
# Override only if your gateway runs on a different host/port.
VO_GATEWAY_URL=ws://host.docker.internal:18789
VO_GATEWAY_HTTP=http://host.docker.internal:18789

# Server ports
VO_PORT=8090
VO_WS_PORT=8091

# Office display name
VO_OFFICE_NAME=Virtual Office

# Weather widget location (optional, e.g. "New+York,NY")
VO_WEATHER_LOCATION=

# Agent Browser VNC password (if using the optional browser service)
# BROWSER_VNC_PASSWORD=changeme

# ── Trading Bot ─────────────────────────────────────────────────────────────
# Leave blank to use paper trading (simulation) mode — no real money at risk.

# Binance (Crypto)
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# Bybit (Crypto)
# BYBIT_API_KEY=
# BYBIT_API_SECRET=

# Alpaca (Stocks / Crypto — paper endpoint used by default)
# ALPACA_API_KEY=
# ALPACA_API_SECRET=

# Claude AI Signal strategy (optional)
# ANTHROPIC_API_KEY=

# Telegram Bot alerts
# 1. Create a bot via @BotFather → /newbot → copy the token
# 2. Send any message to the bot, then open:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your chat_id
# TELEGRAM_BOT_TOKEN=123456:ABC-xyz
# TELEGRAM_CHAT_ID=987654321

# ── Standalone Bot Runner (run_bot.py / Dockerfile.bot) ─────────────────────
# Used when running the bot WITHOUT the web UI (pure cloud mode)

# Exchange: binance | bybit | okx | alpaca
# EXCHANGE=binance
# EXCHANGE_API_KEY=
# EXCHANGE_API_SECRET=
# PAPER_TRADING=true

# Symbols (comma-separated)
# SYMBOLS=BTC/USDT,ETH/USDT

# Interval between strategy ticks (seconds)
# INTERVAL_SECONDS=60

# Strategies to enable (true/false)
# STRATEGY_MA_CROSSOVER=true
# STRATEGY_RSI_MACD=true
# STRATEGY_GRID=false
# STRATEGY_AI_SIGNAL=false
# STRATEGY_MCDX=true
# STRATEGY_SENTINEL=true

# Risk management
# RISK_PER_TRADE=0.02
# STOP_LOSS_PCT=0.03
# TAKE_PROFIT_PCT=0.06
# MAX_POSITIONS=5

# Minimum confidence to send Telegram alert (0.0 - 1.0)
# TG_MIN_CONFIDENCE=0.5

# Log verbosity: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO
