# Quantum Capital Fund — Required API Keys
# Copy to .env and fill in your credentials (never commit .env)

# Alpaca Markets (paper trading: https://app.alpaca.markets/paper-trading)
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Finnhub (free tier: https://finnhub.io/register)
FINNHUB_API_KEY=

# Optional: switch to live trading (default is paper)
# ALPACA_ENV=live
